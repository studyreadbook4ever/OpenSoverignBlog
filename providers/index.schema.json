{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-soverign-blog.invalid/providers/index.schema.json",
  "title": "OpenSoverignBlog monetization provider index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "entries"],
  "properties": {
    "$schema": { "type": "string", "format": "uri" },
    "schemaVersion": { "const": "1.0" },
    "generatedAt": { "type": "string", "format": "date" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "adapterStatus", "lastVerified", "example"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 5,
            "maxLength": 190,
            "pattern": "^[a-z0-9][a-z0-9.-]+[a-z0-9]$"
          },
          "path": {
            "type": "string",
            "pattern": "^providers/[a-z0-9][a-z0-9.-]+\\.ya?ml$"
          },
          "adapterStatus": {
            "enum": ["catalog-only", "community-adapter", "verified-adapter", "core-maintained"]
          },
          "lastVerified": { "type": "string", "format": "date" },
          "example": { "type": "boolean" }
        }
      }
    }
  }
}
