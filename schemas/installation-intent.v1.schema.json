{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:open-soverign-blog:schemas:installation-intent:v1",
  "title": "OpenSoverignBlog installation intent v1",
  "description": "Secret-free, human-owned installation intent. This JSON shape is also the shape produced when osb.install.toml is parsed as TOML.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "installation_id",
    "site_id",
    "created_with",
    "selection"
  ],
  "properties": {
    "schema_version": {
      "const": "open-soverign-blog-install/1"
    },
    "installation_id": {
      "$ref": "#/$defs/uuid"
    },
    "site_id": {
      "$ref": "#/$defs/uuid"
    },
    "created_with": {
      "$ref": "#/$defs/semver"
    },
    "selection": {
      "$ref": "#/$defs/selection"
    },
    "dlcs": {
      "type": "array",
      "maxItems": 256,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/requestedDlc"
      },
      "default": []
    }
  },
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "versionRequirement": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^(?:[<>=~^]{0,2} *(?:\\*|[xX]|0|[1-9][0-9]*)(?:\\.(?:\\*|[xX]|0|[1-9][0-9]*)){0,2}(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?)(?: *, *(?:[<>=~^]{0,2} *(?:\\*|[xX]|0|[1-9][0-9]*)(?:\\.(?:\\*|[xX]|0|[1-9][0-9]*)){0,2}(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?))*$",
      "description": "A bounded semver::VersionReq-compatible comparator list. The Rust contract remains authoritative for semantic range parsing."
    },
    "pluginId": {
      "type": "string",
      "minLength": 5,
      "maxLength": 190,
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?){2,}$"
    },
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._@+-]+(?:/[A-Za-z0-9._@+-]+)*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "style": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": {
              "const": "none"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "id"],
          "properties": {
            "kind": {
              "const": "builtin"
            },
            "id": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "pattern": "^[a-z][a-z0-9_-]{0,63}$"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "file", "sha256"],
          "properties": {
            "kind": {
              "const": "custom"
            },
            "file": {
              "$ref": "#/$defs/safeRelativePath"
            },
            "sha256": {
              "$ref": "#/$defs/sha256"
            }
          }
        }
      ]
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["admin_auth", "style", "cache"],
      "properties": {
        "admin_auth": {
          "enum": ["access_key", "external", "disabled"]
        },
        "style": {
          "$ref": "#/$defs/style"
        },
        "cache": {
          "enum": ["none", "redis_standalone", "redis_managed"]
        }
      }
    },
    "requestedDlc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {
          "$ref": "#/$defs/pluginId"
        },
        "version": {
          "$ref": "#/$defs/versionRequirement"
        },
        "enabled": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
