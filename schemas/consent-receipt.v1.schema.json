{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:opensoverignblog:schema:consent-receipt:v1",
  "title": "OpenSoverignBlog consent receipt v1",
  "description": "Data-minimised evidence of a consent, refusal, or withdrawal event. A valid receipt does not certify that consent was legally valid or that runtime behaviour matched the policy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec_version",
    "receipt_id",
    "policy",
    "occurred_at",
    "source",
    "action",
    "decisions",
    "proof",
    "data_minimisation"
  ],
  "properties": {
    "spec_version": {
      "const": "1.0"
    },
    "receipt_id": {
      "$ref": "#/$defs/stableId"
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_id", "policy_version", "digest"],
      "properties": {
        "policy_id": {
          "$ref": "#/$defs/stableId"
        },
        "policy_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "enum": [
        "banner",
        "privacy-settings",
        "browser-signal",
        "api",
        "import"
      ]
    },
    "action": {
      "enum": [
        "explicit-click",
        "explicit-toggle",
        "software-refusal",
        "withdrawal",
        "api-affirmation",
        "imported"
      ]
    },
    "signal_adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapter_id", "adapter_version", "raw_signal_retained"],
      "properties": {
        "adapter_id": {
          "$ref": "#/$defs/stableId"
        },
        "adapter_version": {
          "type": "string",
          "minLength": 1
        },
        "raw_signal_retained": {
          "type": "boolean"
        },
        "signal_digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "subject_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "enum": ["anonymous-generic-flag", "pseudonymous", "account-linked"]
        },
        "reference": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        }
      },
      "allOf": [
        {
          "if": {
            "type": "object",
            "properties": {
              "mode": {
                "enum": ["pseudonymous", "account-linked"]
              }
            },
            "required": ["mode"]
          },
          "then": {
            "type": "object",
            "properties": {
              "reference": {
                "type": "string",
                "minLength": 1,
                "maxLength": 512
              }
            },
            "required": ["reference"]
          }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "mode": { "const": "anonymous-generic-flag" }
            },
            "required": ["mode"]
          },
          "then": {
            "type": "object",
            "not": { "required": ["reference"] }
          }
        }
      ]
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/decision"
      }
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "presented_locale",
        "ui_content_version",
        "ui_digest",
        "information_snapshot",
        "active_choice",
        "optional_purposes_preselected",
        "accept_reject_manage_available"
      ],
      "properties": {
        "presented_locale": {
          "type": "string",
          "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
        },
        "ui_content_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "ui_digest": {
          "$ref": "#/$defs/digest"
        },
        "information_snapshot": {
          "type": "object",
          "additionalProperties": false,
          "required": ["uri", "digest"],
          "properties": {
            "uri": {
              "type": "string",
              "format": "uri"
            },
            "digest": {
              "$ref": "#/$defs/digest"
            }
          }
        },
        "active_choice": {
          "type": "boolean"
        },
        "optional_purposes_preselected": {
          "const": false
        },
        "accept_reject_manage_available": {
          "const": true
        },
        "interaction_method": {
          "enum": ["pointer", "keyboard", "touch", "voice", "assistive-technology", "api", "software-signal"]
        }
      }
    },
    "data_minimisation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw_ip_stored", "full_user_agent_stored"],
      "properties": {
        "raw_ip_stored": { "const": false },
        "full_user_agent_stored": { "const": false },
        "additional_evidence_categories": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          }
        }
      }
    },
    "supersedes_receipt_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/stableId"
      }
    },
    "withdrawal_effective_at": {
      "type": "string",
      "format": "date-time"
    },
    "processing_result": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "unblocked_resource_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/stableId"
          }
        },
        "blocked_resource_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/stableId"
          }
        },
        "downstream_withdrawal_requested": {
          "type": "boolean"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "type": "object",
        "properties": {
          "decisions": {
            "type": "array",
            "contains": {
              "type": "object",
              "required": ["decision"],
              "properties": {
                "decision": { "const": "granted" }
              }
            }
          }
        },
        "required": ["decisions"]
      },
      "then": {
        "type": "object",
        "properties": {
          "proof": {
            "type": "object",
            "properties": {
              "active_choice": { "const": true }
            }
          }
        }
      }
    },
    {
      "if": {
        "type": "object",
        "properties": {
          "source": { "const": "browser-signal" }
        },
        "required": ["source"]
      },
      "then": {
        "type": "object",
        "properties": {
          "signal_adapter": {
            "type": "object"
          }
        },
        "required": ["signal_adapter"]
      }
    },
    {
      "if": {
        "type": "object",
        "properties": {
          "action": { "const": "software-refusal" }
        },
        "required": ["action"]
      },
      "then": {
        "type": "object",
        "properties": {
          "decisions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "decision": { "enum": ["denied", "withdrawn"] }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "type": "object",
        "properties": {
          "action": { "const": "withdrawal" }
        },
        "required": ["action"]
      },
      "then": {
        "type": "object",
        "required": ["withdrawal_effective_at", "supersedes_receipt_ids"],
        "properties": {
          "withdrawal_effective_at": {
            "type": "string",
            "format": "date-time"
          },
          "supersedes_receipt_ids": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/stableId"
            }
          },
          "decisions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "decision": { "enum": ["denied", "withdrawn"] }
              }
            },
            "contains": {
              "type": "object",
              "required": ["decision"],
              "properties": {
                "decision": { "const": "withdrawn" }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "stableId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value", "canonicalisation"],
      "properties": {
        "algorithm": {
          "enum": ["sha-256", "sha-384", "sha-512"]
        },
        "value": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]+$"
        },
        "canonicalisation": {
          "type": "string",
          "minLength": 1,
          "description": "Exact byte or JSON canonicalisation method, including any excluded digest field."
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["purpose_id", "purpose_revision", "decision", "actor_ids"],
      "properties": {
        "purpose_id": {
          "$ref": "#/$defs/stableId"
        },
        "purpose_revision": {
          "type": "integer",
          "minimum": 1
        },
        "decision": {
          "enum": ["granted", "denied", "withdrawn", "not-required"]
        },
        "actor_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/stableId"
          }
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
