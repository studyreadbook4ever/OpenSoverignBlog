{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:opensoverignblog:schema:macro-invocation:v1",
  "title": "OpenSoverignBlog inert AI macro invocation v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "specVersion",
    "invocationId",
    "macroId",
    "definitionVersion",
    "phase",
    "inputs",
    "actor",
    "policy",
    "requiresReview",
    "createdAt"
  ],
  "properties": {
    "specVersion": { "const": "1.0" },
    "invocationId": { "type": "string", "format": "uuid" },
    "macroId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9._-]*$"
    },
    "definitionVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "phase": { "enum": ["draft", "publish", "request"] },
    "inputs": true,
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "enum": ["human", "agent", "tool", "service"] },
        "id": { "type": "string", "minLength": 1, "maxLength": 300 },
        "provider": { "type": "string", "maxLength": 300 },
        "model": { "type": "string", "maxLength": 300 }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dataBoundary"],
      "properties": {
        "dataBoundary": {
          "enum": ["local_only", "approved_providers", "redact_before_send", "external_allowed"]
        },
        "allowedProviderIds": {
          "type": "array",
          "maxItems": 128,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 300 }
        },
        "allowedCapabilities": {
          "type": "array",
          "maxItems": 128,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 300 }
        },
        "maxCost": { "type": ["number", "null"], "minimum": 0 },
        "maxTokens": { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "contextReceipts": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reference", "contentHash", "scope", "included"],
        "properties": {
          "reference": { "type": "string", "minLength": 1, "maxLength": 2048 },
          "contentHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
          "scope": { "type": "string", "minLength": 1, "maxLength": 100 },
          "included": { "type": "boolean" },
          "exclusionReason": { "type": "string", "minLength": 1, "maxLength": 1000 }
        }
      }
    },
    "requiresReview": { "type": "boolean", "default": true },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
