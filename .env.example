# Copy to .env, or let `osb bootstrap` create it and config.toml together.
OSB_DATA_VOLUME=open-soverign-blog_osb-data
# The verified updater writes an immutable local image ID here after a healthy
# candidate-volume migration. Leave empty for normal source-checkout builds.
OSB_IMAGE=
OSB_CONFIG=/config/config.toml
OSB_CONFIG_SOURCE=./config.toml
OSB_INSTALL_SOURCE=./osb.install.example.toml
OSB_LOCK_SOURCE=./osb.lock.example.json
OSB_INSTALL_LOCK_DIGEST=
# Fail closed by default. Set true only while running a pre-contract local source
# checkout, then adopt/bootstrap, set the lock digest, and restore false.
OSB_ALLOW_UNTRACKED_INSTALLATION=false
OSB_STYLE=custom:replace-with-bootstrap-generated-sha256
OSB_CACHE=redis_managed
OSB_DLC_IDS=org.open-soverign-blog.seo
OSB_CUSTOM_CSS_SOURCE=./custom.css
# Secret-free topology and references-source integrity contract.
OSB_HANDOFF_SOURCE=./osb.intent.example.json
# Host-side portable Markdown mounted read-only at /config/references.md.
# The default source below is Korean; use ./deploy/references.en.md for English.
OSB_REFERENCES_ENABLED=true
OSB_REFERENCES_LABEL=레퍼런스
OSB_REFERENCES_SOURCE=./deploy/references.md

OSB_PORT=8787
OSB_PUBLIC_URL=http://localhost:8787
# Human-facing product language. Supported values: ko, en.
OSB_LANGUAGE=ko
OSB_INTENT=personal
OSB_AUTH_MODE=disabled
OSB_ADMIN_AUTH=access_key
# Standard Base64 of an Argon2id PHC string. Run `osb bootstrap`; never put the
# plaintext administrator access key here.
OSB_ADMIN_ACCESS_KEY_PHC_B64=
OSB_ADMIN_SESSION_DAYS=30
# One-shot recovery/rotation switch. Set true only for a same-module key or
# provider-binding change, then set it back to false. Auth mode is installation
# structure and is not changed by this switch.
OSB_ADMIN_AUTH_ROTATE=false
# Optional static machine credential for the thin MCP adapter's content-only
# write routes. Use 32-128 unpadded Base64url characters. It requires an active
# administrator module and is rejected on delivery-only nodes.
OSB_MCP_TOKEN=
# External mode secrets/config overrides. Non-secret fields normally live in
# [admin.external] in config.toml.
OSB_EXTERNAL_CLIENT_SECRET=
OSB_ARTICLE_BASE_PATH=blog
OSB_SITE_ID=00000000-0000-7000-8000-000000000001
OSB_NO_INDEX=false

OSB_REGISTRATION_OPEN=false
OSB_COMMENTS=false
OSB_COLLABORATION=false
OSB_CUSTOM_CSS=true
OSB_AGENT_DISCOVERY=true
OSB_DELIVERY_ONLY=false
OSB_FEATURES=seo

# Optional Kakao AdFit adapter. Enable the bundled ads DLC/feature, then replace
# all four blank browser-visible DAN unit identifiers together.
OSB_KAKAO_ADFIT_PC_TOP_UNIT=
OSB_KAKAO_ADFIT_PC_BOTTOM_UNIT=
OSB_KAKAO_ADFIT_MOBILE_TOP_UNIT=
OSB_KAKAO_ADFIT_MOBILE_BOTTOM_UNIT=

# Redis is an optional derivative-cache DLC. Set false to run directly from the
# authoritative SQLite/blob origin. The bundled managed profile discovers its
# writable Redis node through three Sentinels.
OSB_REDIS_ENABLED=true
OSB_REDIS_TOPOLOGY=sentinel
OSB_REDIS_URL=redis://redis-primary:6379/
OSB_REDIS_SENTINELS=redis://redis-sentinel-1:26379/,redis://redis-sentinel-2:26379/,redis://redis-sentinel-3:26379/
OSB_REDIS_SENTINEL_MASTER=osb-primary
OSB_REDIS_REQUIRED=true
# Intentionally empty: Compose fails closed until `osb bootstrap` generates a
# secret or the operator supplies 32-128 URL-safe random characters.
OSB_REDIS_PASSWORD=
# Separate application-only HMAC key. Redis never receives this value, so a
# writable/corrupted cache cannot forge a canonical-looking public response.
OSB_CACHE_SIGNING_KEY=
OSB_CONTENT_RELEASE=live
OSB_REDIS_MAXMEMORY=256mb

# Informational release checks never execute remote content. Disable this for a
# fully offline installation; the footer will report that checks are disabled.
OSB_UPDATE_CHECKS=true
OSB_UPDATE_CHANNEL_URL=https://raw.githubusercontent.com/studyreadbook4ever/OpenSoverignBlog/main/release-channel.json
OSB_UPDATE_CHECK_INTERVAL_SECONDS=21600

OSB_DATABASE_PROFILE=durable
OSB_MANAGED_BACKUPS=true
OSB_BACKUP_VOLUME=./.osb-backups
OSB_BACKUP_INTERVAL_MINUTES=15
OSB_BACKUP_RETENTION=96

RUST_LOG=info
