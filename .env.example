# Copy to .env, or let `osb bootstrap` create it and config.toml together.
OSB_CONFIG=/config/config.toml
OSB_CONFIG_SOURCE=./config.toml
OSB_CUSTOM_CSS_SOURCE=./custom.css

OSB_PORT=8787
OSB_PUBLIC_URL=http://localhost:8787
OSB_INTENT=personal
OSB_AUTH_MODE=local
OSB_ARTICLE_BASE_PATH=blog
OSB_SITE_ID=00000000-0000-7000-8000-000000000001
OSB_NO_INDEX=false

OSB_REGISTRATION_OPEN=false
OSB_COMMENTS=false
OSB_COLLABORATION=false
OSB_CUSTOM_CSS=true
OSB_AGENT_DISCOVERY=true
OSB_DELIVERY_ONLY=false
OSB_FEATURES=seo

# Redis is mandatory for the public hot path. The bundled Compose topology
# discovers its writable node through three Sentinels.
OSB_REDIS_TOPOLOGY=sentinel
OSB_REDIS_URL=redis://redis-primary:6379/
OSB_REDIS_SENTINELS=redis://redis-sentinel-1:26379/,redis://redis-sentinel-2:26379/,redis://redis-sentinel-3:26379/
OSB_REDIS_SENTINEL_MASTER=osb-primary
OSB_REDIS_REQUIRED=true
# Intentionally empty: Compose fails closed until `osb bootstrap` generates a
# secret or the operator supplies 32-128 URL-safe random characters.
OSB_REDIS_PASSWORD=
# Separate application-only HMAC key. Redis never receives this value, so a
# writable/corrupted cache cannot forge a canonical-looking public response.
OSB_CACHE_SIGNING_KEY=
OSB_CONTENT_RELEASE=live
OSB_REDIS_MAXMEMORY=256mb

OSB_DATABASE_PROFILE=durable
OSB_MANAGED_BACKUPS=true
OSB_BACKUP_VOLUME=./.osb-backups
OSB_BACKUP_INTERVAL_MINUTES=15
OSB_BACKUP_RETENTION=96

# Optional legacy single-owner token. Local account sessions do not use it.
OSB_ADMIN_TOKEN=
RUST_LOG=info
